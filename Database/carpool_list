  `driver_id` bigint unsigned NOT NULL,
  `from_place` varchar(255) NOT NULL,
  `to_place` varchar(255) NOT NULL,
  `date` date NOT NULL,
  `time` time NOT NULL,
  `seats` int NOT NULL,
  `bording_point` varchar(255) NOT NULL,
  `status_open_close` varchar(255) NOT NULL,
  PRIMARY KEY (`cl_id`),
  UNIQUE KEY `cl_id` (`cl_id`),
  KEY `fk_carpool_list_driver_id` (`driver_id`),
