CREATE TABLE `redeem_record` (
  `RR_ID` bigint unsigned NOT NULL AUTO_INCREMENT,
  `User_ID` bigint unsigned NOT NULL,
  `Items_ID` bigint unsigned NOT NULL,
  `Points_spent` int NOT NULL,
  `Quantity` int NOT NULL,
  `Date` date NOT NULL,
  PRIMARY KEY (`RR_ID`),
  UNIQUE KEY `RR_ID` (`RR_ID`),
  KEY `fk_record_user` (`User_ID`),
  KEY `fk_record_items` (`Items_ID`),
  CONSTRAINT `fk_record_items` FOREIGN KEY (`Items_ID`) REFERENCES `items` (`Items_ID`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `fk_record_user` FOREIGN KEY (`User_ID`) REFERENCES `user_acc` (`user_id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci