  `status` varchar(255) NOT NULL,
  `user_id` bigint unsigned NOT NULL,
  PRIMARY KEY (`journey_id`),
  UNIQUE KEY `journey_id` (`journey_id`),
  KEY `fk_journey_user_id` (`user_id`),
